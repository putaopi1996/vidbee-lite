{
  "name": "vidbee-workspace",
  "private": true,
  "scripts": {
    "check": "pnpm -r --parallel --filter ./apps/api --filter ./apps/web run check",
    "typecheck": "pnpm -r --parallel --filter ./apps/api --filter ./apps/web run typecheck",
    "dev": "pnpm -r --parallel --filter ./apps/api --filter ./apps/web run dev",
    "start": "pnpm -r --parallel --filter ./apps/api --filter ./apps/web run start",
    "build": "pnpm -r --parallel --filter ./apps/api --filter ./apps/web run build",
    "dev:api": "pnpm --filter ./apps/api run dev",
    "start:api": "pnpm --filter ./apps/api run start",
    "check:api": "pnpm --filter ./apps/api run check",
    "dev:web": "pnpm --filter ./apps/web run dev",
    "build:web": "pnpm --filter ./apps/web run build",
    "check:web": "pnpm --filter ./apps/web run check",
    "dev:docs": "pnpm --filter ./apps/docs dev",
    "build:docs": "pnpm --filter ./apps/docs build",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
